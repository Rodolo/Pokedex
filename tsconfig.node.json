{
  "compilerOptions": {
    "composite": true,

    "target": "ES2023",

    "lib": ["ES2023"],

    "module": "ESNext",
    "moduleResolution": "bundler",

    "types": ["node"],

    "allowImportingTsExtensions": true,

    "verbatimModuleSyntax": true,

    "skipLibCheck": true,

    "noEmit": true
  },

  "include": [
    "vite.config.ts"
  ]
}