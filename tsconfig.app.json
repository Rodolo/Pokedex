{
  "compilerOptions": {
    "target": "ES2022",

    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],

    "module": "ESNext",
    "moduleResolution": "bundler",

    "jsx": "react-jsx",

    "strict": true,

    "isolatedModules": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,

    "esModuleInterop": true,

    "paths": {
      "@/*": ["./src/*"]
    },

    "skipLibCheck": true,

    "noEmit": true
  },

  "include": [
    "src"
  ]
}